// AUTO-GENERATED by generate.sh — edit src/ files instead
// Rust devcontainer template
// Customize: rust toolchain, additional targets, forwarded ports
{
  "name": "${projectName}",
  "initializeCommand": "token=$(gh auth token 2>/dev/null) && echo \"GH_TOKEN=$token\" > .devcontainer/.env.secrets || : > .devcontainer/.env.secrets",
  "image": "mcr.microsoft.com/devcontainers/rust:1",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "serayuzgur.crates"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "rust-analyzer.check.command": "clippy"
      }
    }
  },
  "postCreateCommand": {
    "cli-tools": "npm install -g @anthropic-ai/claude-code @fission-ai/openspec@latest",
    "claude-toolbox": "if [ -x \"$HOME/.claude/toolbox/bin/claude-toolbox\" ]; then mkdir -p \"$HOME/.local/bin\" && ln -sf \"$HOME/.claude/toolbox/bin/claude-toolbox\" \"$HOME/.local/bin/claude-toolbox\"; fi",
    "project-deps": "cargo build"
  },
  "runArgs": [
    "--env-file",
    ".devcontainer/.env.secrets"
  ],
  "containerEnv": {
    "TZ": "America/New_York"
  },
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/vscode/.config/gh,type=bind,readonly",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude/toolbox,target=/home/vscode/.claude/toolbox,type=bind,readonly"
  ],
  "forwardPorts": [],
  "remoteUser": "vscode"
}
